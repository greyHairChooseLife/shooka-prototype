# YouTube Data API v3
YOUTUBE_API_KEY=

# LLM Provider: openai (default) | anthropic | gemini
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 호출 제한 (24시간)
USAGE_LIMIT_PER_DAY=15

# 채널 ID (seed-channels.ts로 확인)
SHOOKAWORLD_CHANNEL_ID=
MONEYCOMICS_CHANNEL_ID=

# DB 경로
DB_PATH=./data/app.db

# 도메인 (Caddy용, 개발 중 비워둠)
DOMAIN=
